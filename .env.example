# Mac App Store build settings.
# Copy to a local shell/session and fill real values manually.
# Do not commit real certificates, passwords, API keys, or .p8 private keys.

# Must match the Bundle ID registered in Apple Developer and App Store Connect.
APPSTORE_BUNDLE_IDENTIFIER=com.mdquicklook.desktop

# App Store Connect versioning recommendation:
# Use a stable numeric marketing version for App Store builds, and describe beta status in TestFlight notes.
APPSTORE_MARKETING_VERSION=1.0.0
APPSTORE_BUILD_NUMBER=1

# Apple Developer Team ID.
APPLE_TEAM_ID=88Y78WLD7A

# App bundle signing identity. Use the SHA-1 fingerprint when duplicate certificate
# names exist in Keychain.
APPLE_SIGNING_IDENTITY=EDC962A1E55F41C70B15CC5CC009E32E6A21C50A

# Installer package signing identity for App Store upload. Use the SHA-1 fingerprint
# when duplicate certificate names exist in Keychain.
MAC_INSTALLER_SIGNING_IDENTITY=E0A5EC494A3584AE79065A08688507531F6CF8AE

# Absolute path to a Mac App Store Connect provisioning profile matching:
# ${APPLE_TEAM_ID}.${APPSTORE_BUNDLE_IDENTIFIER}
# Current Apple Developer profile name: mdquicklook Mac App Store 20260612
APPSTORE_PROVISION_PROFILE=

# Optional target. Defaults to universal-apple-darwin.
# Allowed: universal-apple-darwin, aarch64-apple-darwin, x86_64-apple-darwin, native
TAURI_APPSTORE_TARGET=universal-apple-darwin

# App Store Connect upload credentials.
# The private key file must be named AuthKey_<APPLE_API_KEY_ID>.p8 and placed in one of:
# ./private_keys, ~/private_keys, ~/.private_keys, ~/.appstoreconnect/private_keys
APPLE_API_KEY_ID=
APPLE_API_ISSUER=
